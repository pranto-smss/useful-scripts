<html>
<head>
<title>WiFi Manager</title>
<HTA:APPLICATION
    ID="WiFiManager"
    APPLICATIONNAME="WiFi Manager"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    ICON=""
    INNERBORDER="no"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    VERSION="1.0"
    SCROLL="no"
    WIDTH="540"
    HEIGHT="800"
/>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #1a1a2e;
        color: #e0e0e0;
        padding: 15px;
        font-size: 13px;
        position: relative;
    }
    h1 {
        font-size: 18px;
        font-weight: 600;
        color: #00d4ff;
        margin-bottom: 12px;
        text-align: center;
    }
    .toolbar {
        display: table;
        width: 100%;
        margin-bottom: 12px;
        border-spacing: 6px;
    }
    .toolbar-row {
        display: table-row;
    }
    .toolbar-cell {
        display: table-cell;
        width: 33%;
    }
    button {
        width: 100%;
        padding: 8px 12px;
        border: none;
        border-radius: 5px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
    }
    .btn-primary { background: #00d4ff; color: #1a1a2e; }
    .btn-primary:hover { background: #00b8d4; }
    .btn-success { background: #00e676; color: #1a1a2e; }
    .btn-success:hover { background: #00c853; }
    .btn-danger { background: #ff5252; color: #fff; }
    .btn-danger:hover { background: #ff1744; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .network-list {
        border: 1px solid #333;
        border-radius: 5px;
        height: 570px;
        overflow-y: auto;
        background: #0f0f23;
    }
    .network-item {
        padding: 10px 12px;
        border-bottom: 1px solid #222;
        cursor: pointer;
    }
    .network-item:hover { background: #1a1a3e; }
    .network-item.selected { background: #00d4ff15; border-left: 3px solid #00d4ff; padding-left: 9px; }
    .network-header { display: table; width: 100%; }
    .network-name {
        font-weight: 600;
        font-size: 13px;
        color: #fff;
        display: table-cell;
    }
    .network-badge {
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 3px;
        display: table-cell;
        text-align: right;
        vertical-align: middle;
    }
    .badge-connected { background: #00e67633; color: #00e676; }
    .network-auth {
        font-size: 11px;
        color: #888;
        margin-top: 2px;
    }
    .network-password {
        margin-top: 8px;
        padding: 8px 10px;
        background: #16213e;
        border-radius: 4px;
    }
    .password-row { display: table; width: 100%; }
    .password-label {
        font-size: 10px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 3px;
    }
    .password-value {
        font-family: 'Consolas', monospace;
        font-size: 14px;
        color: #00e676;
        letter-spacing: 1px;
        word-break: break-all;
        display: table-cell;
    }
    .password-copy {
        font-size: 11px;
        color: #00d4ff;
        cursor: pointer;
        display: table-cell;
        text-align: right;
        vertical-align: middle;
        white-space: nowrap;
        padding-left: 10px;
    }
    .password-copy:hover { text-decoration: underline; }
    .password-forget {
        margin-top: 6px;
        font-size: 11px;
        color: #ff5252;
        cursor: pointer;
    }
    .password-forget:hover { text-decoration: underline; }
    .status-bar {
        position: absolute;
        bottom: 15px;
        left: 15px;
        right: 15px;
        padding: 6px 10px;
        background: #0f0f23;
        border-radius: 4px;
        font-size: 11px;
        color: #888;
        text-align: center;
    }
    .status-bar.success { color: #00e676; }
    .status-bar.error { color: #ff5252; }
    .scrollbar::-webkit-scrollbar { width: 6px; }
    .scrollbar::-webkit-scrollbar-track { background: #0f0f23; }
    .scrollbar::-webkit-scrollbar-thumb { background: #444; border-radius: 3px; }
</style>
</head>
<body>
    <h1>WiFi Manager</h1>

    <div class="toolbar">
        <div class="toolbar-row">
            <div class="toolbar-cell">
                <button class="btn-primary" onclick="refreshNetworks()">Refresh</button>
            </div>
            <div class="toolbar-cell">
                <button class="btn-success" id="btnShowPassword" onclick="togglePassword()" disabled>Show Password</button>
            </div>
            <div class="toolbar-cell">
                <button class="btn-success" id="btnConnect" onclick="toggleConnect()" disabled>Connect</button>
            </div>
        </div>
    </div>

    <div class="network-list scrollbar" id="networkList">
        <div style="padding: 20px; text-align: center; color: #666;">
            Click "Refresh" to load saved WiFi networks...
        </div>
    </div>

    <div class="status-bar" id="statusBar">Ready</div>

<script language="JavaScript">
var selectedNetwork = "";
var passwordVisible = false;
var connectedSSID = "";
var networkData = [];

function runCommand(cmd) {
    var shell = new ActiveXObject("WScript.Shell");
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    var tmpFile = shell.ExpandEnvironmentStrings("%TEMP%") + "\\~wifi_mgr_tmp.txt";
    shell.Run("cmd.exe /c " + cmd + ' > "' + tmpFile + '" 2>&1', 0, true);
    var output = "";
    if (fso.FileExists(tmpFile)) {
        var f = fso.OpenTextFile(tmpFile, 1);
        output = f.ReadAll();
        f.Close();
        fso.DeleteFile(tmpFile, true);
    }
    return output;
}

function getConnectedSSID() {
    var output = runCommand("netsh wlan show interfaces");
    var lines = output.split("\r\n");
    for (var i = 0; i < lines.length; i++) {
        var line = lines[i].replace(/^\s+/, "");
        if (line.indexOf("SSID") > -1 && line.indexOf("BSSID") === -1 && line.indexOf(":") > -1) {
            var val = line.split(":")[1].replace(/^\s+/, "").replace(/\s+$/, "");
            if (val !== "") return val;
        }
    }
    return "";
}

function refreshNetworks() {
    document.getElementById("statusBar").innerText = "Loading networks...";
    document.getElementById("statusBar").className = "status-bar";

    connectedSSID = getConnectedSSID();

    var output = runCommand("netsh wlan show profiles");
    var lines = output.split("\r\n");
    var networks = [];

    for (var i = 0; i < lines.length; i++) {
        var line = lines[i].replace(/^\s+/, "");
        if (line.indexOf("All User Profile") > -1 || line.indexOf("User Profile") > -1) {
            if (line.indexOf(":") > -1) {
                var name = line.split(":")[1].replace(/^\s+/, "").replace(/\s+$/, "");
                if (name !== "") {
                    networks.push(name);
                }
            }
        }
    }

    networkData = networks;
    renderNetworks();

    document.getElementById("statusBar").innerText = "Found " + networks.length + " saved network(s)";
    document.getElementById("statusBar").className = "status-bar success";

    selectedNetwork = "";
    passwordVisible = false;
    updateButtons();
}

function renderNetworks() {
    var listHtml = "";
    if (networkData.length === 0) {
        listHtml = '<div style="padding: 20px; text-align: center; color: #666;">No saved WiFi networks found.</div>';
    } else {
        for (var j = 0; j < networkData.length; j++) {
            var name = networkData[j];
            var isSelected = (name === selectedNetwork);
            var cls = isSelected ? "network-item selected" : "network-item";

            listHtml += '<div class="' + cls + '" onclick="selectNetwork(this, \'' + escapeHtml(name) + '\')">';
            listHtml += '<div class="network-header">';
            listHtml += '<div class="network-name">' + escapeHtml(name) + '</div>';
            if (name === connectedSSID) {
                listHtml += '<div class="network-badge badge-connected">Connected</div>';
            }
            listHtml += '</div>';
            listHtml += '<div class="network-auth">Saved network</div>';

            if (isSelected && passwordVisible) {
                listHtml += '<div class="network-password" id="pwSection">';
                listHtml += '<div class="password-label">Password</div>';
                listHtml += '<div class="password-row">';
                listHtml += '<div class="password-value" id="passwordValue">Loading...</div>';
                listHtml += '<div class="password-copy" onclick="event.stopPropagation(); copyPassword()">Copy</div>';
                listHtml += '</div>';
                listHtml += '<div class="password-forget" onclick="event.stopPropagation(); forgetNetwork()">Forget this network</div>';
                listHtml += '</div>';
            }

            listHtml += '</div>';
        }
    }
    document.getElementById("networkList").innerHTML = listHtml;
}

function selectNetwork(element, name) {
    selectedNetwork = name;
    passwordVisible = false;
    renderNetworks();
    updateButtons();

    document.getElementById("statusBar").innerText = "Selected: " + name;
    document.getElementById("statusBar").className = "status-bar";
}

function updateButtons() {
    var hasSelection = (selectedNetwork !== "");
    document.getElementById("btnShowPassword").disabled = !hasSelection;
    document.getElementById("btnConnect").disabled = !hasSelection;

    if (hasSelection) {
        if (passwordVisible) {
            document.getElementById("btnShowPassword").innerText = "Hide Password";
        } else {
            document.getElementById("btnShowPassword").innerText = "Show Password";
        }

        if (selectedNetwork === connectedSSID) {
            document.getElementById("btnConnect").innerText = "Disconnect";
            document.getElementById("btnConnect").className = "btn-danger";
        } else {
            document.getElementById("btnConnect").innerText = "Connect";
            document.getElementById("btnConnect").className = "btn-success";
        }
    } else {
        document.getElementById("btnShowPassword").innerText = "Show Password";
        document.getElementById("btnConnect").innerText = "Connect";
        document.getElementById("btnConnect").className = "btn-success";
    }
}

function togglePassword() {
    if (!selectedNetwork) return;

    if (passwordVisible) {
        passwordVisible = false;
        renderNetworks();
        updateButtons();
        return;
    }

    document.getElementById("statusBar").innerText = "Loading password...";
    document.getElementById("statusBar").className = "status-bar";

    var cmd = 'netsh wlan show profile "' + selectedNetwork + '" key=clear';
    var output = runCommand(cmd);
    var lines = output.split("\r\n");
    var password = "";

    for (var i = 0; i < lines.length; i++) {
        var line = lines[i].replace(/^\s+/, "");
        if (line.indexOf("Key Content") > -1 && line.indexOf(":") > -1) {
            password = line.split(":")[1].replace(/^\s+/, "").replace(/\s+$/, "");
            break;
        }
    }

    passwordVisible = true;
    renderNetworks();
    updateButtons();

    var pwEl = document.getElementById("passwordValue");
    if (pwEl) {
        if (password) {
            pwEl.innerText = password;
            document.getElementById("statusBar").innerText = "Password loaded for: " + selectedNetwork;
            document.getElementById("statusBar").className = "status-bar success";
        } else {
            pwEl.innerText = "(open network or no password saved)";
            document.getElementById("statusBar").innerText = "No password found for: " + selectedNetwork;
            document.getElementById("statusBar").className = "status-bar";
        }
    }
}

function copyPassword() {
    var pwEl = document.getElementById("passwordValue");
    if (!pwEl) return;
    var pw = pwEl.innerText;
    if (!pw || pw.indexOf("(") === 0) return;

    var shell = new ActiveXObject("WScript.Shell");
    shell.Run("cmd.exe /c echo " + pw + "| clip", 0, true);

    var copyEl = document.getElementById("networkList");
    var statusEl = document.getElementById("statusBar");
    statusEl.innerText = "Password copied!";
    statusEl.className = "status-bar success";
}

function toggleConnect() {
    if (!selectedNetwork) return;

    if (selectedNetwork === connectedSSID) {
        document.getElementById("statusBar").innerText = "Disconnecting...";
        document.getElementById("statusBar").className = "status-bar";

        var output = runCommand("netsh wlan disconnect");

        if (output.indexOf("successfully") > -1) {
            connectedSSID = "";
            document.getElementById("statusBar").innerText = "Disconnected from WiFi";
            document.getElementById("statusBar").className = "status-bar success";
        } else {
            document.getElementById("statusBar").innerText = "No active WiFi connection";
            document.getElementById("statusBar").className = "status-bar";
        }
    } else {
        document.getElementById("statusBar").innerText = "Connecting to " + selectedNetwork + "...";
        document.getElementById("statusBar").className = "status-bar";

        var output = runCommand('netsh wlan connect name="' + selectedNetwork + '"');

        if (output.indexOf("successfully") > -1) {
            connectedSSID = selectedNetwork;
            document.getElementById("statusBar").innerText = "Connected to " + selectedNetwork;
            document.getElementById("statusBar").className = "status-bar success";
        } else {
            document.getElementById("statusBar").innerText = "Connection failed. Password may be required.";
            document.getElementById("statusBar").className = "status-bar error";
        }
    }

    renderNetworks();
    updateButtons();
}

function forgetNetwork() {
    if (!selectedNetwork) return;

    var answer = window.confirm("Forget network '" + selectedNetwork + "'?\n\nThis will remove it from your saved networks.");
    if (!answer) return;

    document.getElementById("statusBar").innerText = "Forgetting " + selectedNetwork + "...";
    document.getElementById("statusBar").className = "status-bar";

    var output = runCommand('netsh wlan delete profile name="' + selectedNetwork + '"');

    if (output.indexOf("successfully") > -1) {
        document.getElementById("statusBar").innerText = "Forgotten: " + selectedNetwork;
        document.getElementById("statusBar").className = "status-bar success";
        selectedNetwork = "";
        passwordVisible = false;
        refreshNetworks();
    } else {
        document.getElementById("statusBar").innerText = "Failed to forget network";
        document.getElementById("statusBar").className = "status-bar error";
    }
}

function escapeHtml(text) {
    var div = document.createElement("div");
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
}

window.onload = function() {
    window.resizeTo(540, 800);
    refreshNetworks();
};
</script>
</body>
</html>
